# App
PORT=3000
NODE_ENV=production

# Database — Railway provê isso automaticamente
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Redis — Railway provê isso automaticamente  
REDIS_URL=redis://default:pass@host:6379

# JWT — gere com: openssl rand -hex 64
JWT_SECRET=GERE_UM_SECRET_FORTE_AQUI
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=GERE_OUTRO_SECRET_FORTE_AQUI
JWT_REFRESH_EXPIRES_IN=7d

# Cloudflare R2 (substitui MinIO em produção)
R2_ACCOUNT_ID=seu_account_id
R2_ACCESS_KEY_ID=seu_access_key
R2_SECRET_ACCESS_KEY=seu_secret_key
R2_BUCKET=minha-rede
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Google OAuth
GOOGLE_CLIENT_ID=seu_client_id
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_CALLBACK_URL=https://seu-backend.railway.app/api/v1/auth/google/callback

# Invite
INVITE_SECRET=GERE_UM_SECRET_AQUI

# CORS
ALLOWED_ORIGINS=https://seu-app.vercel.app,https://seudominio.com
